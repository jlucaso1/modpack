{
  "schemaVersion": 1,
  "id": "ukus-armor-hud",
  "version": "${version}",
  "name": "uku's Armor HUD",
  "description": "This mod adds a minimalistic vanilla-like widget that shows your armor items and a warning if durability is low enough. Forked by uku.",
  "authors": [
    "BerdinskiyBear",
    "uku"
  ],
  "contributors": [
    "AnAwesomGuy"
  ],
  "contact": {
    "homepage": "https://github.com/uku3lig/armor-hud",
    "issues": "https://github.com/uku3lig/armor-hud/issues"
  },
  "license": "MIT",
  "icon": "assets/ukus-armor-hud/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "ru.berdinskiybear.armorhud.fabric.ArmorHudFabric"
    ],
    "ukulib": [
      "ru.berdinskiybear.armorhud.config.UkulibIntegration"
    ]
  },
  "mixins": [
    "ukus-armor-hud.mixins.json"
  ],
  "depends": {
    "minecraft": "^26.1-",
    "fabricloader": ">=0.18",
    "ukulib": "^2.0.0-",
    "fabric-resource-loader-v1": "*"
  },
  "breaks": {
    "armor_hud": "*"
  }
}
